# VDOWN Backend Configuration

# ── Server ──
HOST=0.0.0.0
PORT=8080
DEBUG=False

# ── CORS (for React dev server) ──
VIDOWN_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Subtitle System ──
# Whisper model: tiny, base, small, medium, large, large-v2, large-v3
WHISPER_MODEL=base
WHISPER_DEVICE=auto  # auto, cuda, cpu
WHISPER_COMPUTE_TYPE=default  # default, int8, float16

# Cache settings
SUBTITLE_CACHE_DIR=./cache/subtitles
SUBTITLE_CACHE_TTL_DAYS=30

# Processing limits
MAX_VIDEO_DURATION_SECONDS=7200  # 2 hours
MAX_AUDIO_SIZE_MB=500

# Subtitle formats
SUPPORTED_SUBTITLE_FORMATS=srt,vtt,txt

# Fallback behavior
ENABLE_AI_SUBTITLES=True
AI_SUBTITLE_TIMEOUT_SECONDS=600  # 10 minutes

# ── Redis (for background jobs) ──
REDIS_URL=redis://localhost:6379/0

# ── Downloads ──
DOWNLOAD_DIR=./downloads
DOWNLOAD_CLEANUP_MINUTES=5

# ── AI Video Enhance (upscaling) ──
# When a Real-ESRGAN binary is available it is used for true neural
# super-resolution; otherwise VDown falls back to a high-quality FFmpeg
# Lanczos + unsharp upscaler (GPU-free, works everywhere).
# Install: https://github.com/xinntao/Real-ESRGAN (realesrgan-ncnn-vulkan)
ENABLE_REALESRGAN=True
REALESRGAN_BIN=realesrgan-ncnn-vulkan   # path or command name
REALESRGAN_MODEL=realesrgan-x4plus      # or realesrgan-x4plus-anime
REALESRGAN_MAX_SECONDS=180              # skip neural upscale for longer clips
